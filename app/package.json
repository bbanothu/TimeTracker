    "typescript": "~5.9.2"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "format": "prettier --write .",
    "build:android": "eas build --profile production --platform android",
    "build:ios": "eas build --profile production --platform ios",
    "build:all": "eas build --profile production --platform all",
    "release:android": "eas build --profile production --platform android --auto-submit",
    "release:ios": "eas build --profile production --platform ios --auto-submit",
    "publish:android": "eas submit --profile production --platform android --latest",
    "publish:ios": "eas submit --profile production --platform ios --latest",
    "publish:all": "eas submit --profile production --platform all --latest"
  },
  "private": true
